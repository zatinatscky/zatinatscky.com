# Шаблон переменных для docker-compose. Скопируйте в .env и подставьте секреты:
#   cp .env.example .env  &&  nano .env
# Файл .env НЕ коммитится (см. .gitignore).

# --- PostgreSQL ---
POSTGRES_USER=ivan
POSTGRES_DB=zatinatscky
# Длинный случайный пароль. Сгенерировать: openssl rand -hex 24
POSTGRES_PASSWORD=CHANGE_ME_LONG_RANDOM_PASSWORD

# --- Приложение ---
# Host, на котором / отдаёт welcome IVAN (а не визитку).
DASH_ROOT_HOST=ivan.zatinatscky.com
# Токен для эндпоинта синхронизации /jobs/fng-sync. Сгенерировать: openssl rand -hex 32
CRON_TOKEN=CHANGE_ME_LONG_RANDOM_TOKEN
