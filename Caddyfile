# Caddy сам получает и продлевает TLS-сертификат Let's Encrypt для домена.
# Условие: DNS-запись ivan.zatinatscky.com (A) указывает на IP сервера, порты 80/443 открыты.

ivan.zatinatscky.com {
	# Проксируем на web-контейнер по внутренней сети compose (имя сервиса = web).
	reverse_proxy web:8050
	encode gzip zstd

	# Логи доступа в stdout контейнера (docker compose logs caddy).
	log {
		output stdout
	}
}
