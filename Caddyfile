# Caddy сам получает и продлевает TLS-сертификаты Let's Encrypt для доменов.
# Условие: A-записи доменов указывают на IP сервера, порты 80/443 открыты.

# Субдомен продукта IVAN (welcome + дашборды).
ivan.zatinatscky.com {
	# Проксируем на web-контейнер по внутренней сети compose (имя сервиса = web).
	reverse_proxy web:8050
	encode gzip zstd

	# Логи доступа в stdout контейнера (docker compose logs caddy).
	log {
		output stdout
	}
}

# Апекс — сайт-визитка консалтинга (тот же Flask, контент по Host).
zatinatscky.com {
	reverse_proxy web:8050
	encode gzip zstd

	log {
		output stdout
	}
}

# www → апекс (раскомментируйте, если заведёте DNS-запись www).
# www.zatinatscky.com {
# 	redir https://zatinatscky.com{uri} permanent
# }
